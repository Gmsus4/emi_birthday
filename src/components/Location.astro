---
import { invitation } from "../data/invitation";

const buildEmbedUrl = (q: string) => `https://maps.google.com/maps?q=${encodeURIComponent(q)}&t=&z=15&ie=UTF8&iwloc=&output=embed`;
const buildLinkUrl = (q: string) => `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(q)}`;
---

<section id="ubicacion" class="w-full py-16 px-4 bg-[linear-gradient(135deg,#e8d8b8_0%,#ecdfc4_50%,#f5ead4_100%)]">
  <div class="max-w-5xl mx-auto flex flex-col items-center">
    <h2 class="font-script text-pooh-brown-dark text-[clamp(3rem,8vw,5rem)] text-center m-0 leading-none">Ubicación</h2>
    <img src="friends.png" alt="" aria-hidden="true" class="w-96 md:w-96 my-6 opacity-90 -mb-1" />

    <div class="w-full grid grid-cols-1 md:grid-cols-2 gap-8 mt-1">
      {
        invitation.locations.map((loc) => (
          <div class="flex flex-col items-center">
            {/* <h3 class="font-serif text-pooh-brown-dark text-2xl md:text-3xl font-semibold text-center mb-4 flex items-center justify-center gap-2">
              <loc.icon class="w-8 h-8 text-pooh-brown shrink-0" />
              {loc.label}
            </h3> */}
            <div class="w-full rounded-2xl overflow-hidden border-2 border-pooh-brown-light shadow-lg">
              <iframe
                src={buildEmbedUrl(loc.mapsQuery)}
                width="100%"
                height="280"
                style="border:0;"
                allowfullscreen=""
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
                title={`Mapa de ${loc.label}`}
                class="block w-full"
              />
            </div>
            <p class="font-serif text-pooh-brown-dark text-base md:text-lg italic text-center mt-4 max-w-sm leading-snug">{loc.address}</p>
            <a
              href={buildLinkUrl(loc.mapsQuery)}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 mt-4 px-5 py-2.5 rounded-full bg-yellow text-pooh-brown font-serif font-semibold text-sm tracking-wider no-underline transition-opacity hover:opacity-90"
            >
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
                <circle cx="12" cy="10" r="3" />
              </svg>
              Cómo llegar
            </a>
          </div>
        ))
      }
    </div>
  </div>
</section>
