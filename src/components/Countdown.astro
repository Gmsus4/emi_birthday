<div class="flex gap-3 absolute md:bottom-20 md:top-auto top-10">
    <div class="flex flex-col items-center bg-white/80 backdrop-blur-sm rounded-2xl px-4 py-2 border-b-[4px] border-gray-300 min-w-[60px]"
        data-aos="fade-up" data-aos-delay="700" data-aos-offset="0">
        <span id="days" class="text-3xl md:text-5xl font-extrabold text-primary">00</span>
        <span class="text-xs font-bold text-gray-500 uppercase">Días</span>
    </div>
    <div class="flex flex-col items-center bg-white/80 backdrop-blur-sm rounded-2xl px-4 py-2 border-b-[4px] border-gray-300 min-w-[60px]"
        data-aos="fade-up" data-aos-delay="800" data-aos-offset="0">
        <span id="hours" class="text-3xl md:text-5xl font-extrabold text-primary">00</span>
        <span class="text-xs font-bold text-gray-500 uppercase">Horas</span>
    </div>
    <div class="flex flex-col items-center bg-white/80 backdrop-blur-sm rounded-2xl px-4 py-2 border-b-[4px] border-gray-300 min-w-[60px]"
        data-aos="fade-up" data-aos-delay="900" data-aos-offset="0">
        <span id="minutes" class="text-3xl md:text-5xl font-extrabold text-primary">00</span>
        <span class="text-xs font-bold text-gray-500 uppercase">Min</span>
    </div>
    <div class="flex flex-col items-center bg-white/80 backdrop-blur-sm rounded-2xl px-4 py-2 border-b-[4px] border-gray-300 min-w-[60px]"
        data-aos="fade-up" data-aos-delay="1000" data-aos-offset="0">
        <span id="seconds" class="text-3xl md:text-5xl font-extrabold text-primary">00</span>
        <span class="text-xs font-bold text-gray-500 uppercase">Seg</span>
    </div>
</div>

<script>
    const eventDate = new Date('2026-07-26T14:30:00');

    function updateTimer() {
        const now = new Date();
        const diff = eventDate.getTime() - now.getTime();

        if (diff <= 0) {
            ['days','hours','minutes','seconds'].forEach(id => {
                document.getElementById(id)!.textContent = '00';
            });
            return;
        }

        const days = Math.floor(diff / (1000 * 60 * 60 * 24));
        const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
        const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
        const seconds = Math.floor((diff % (1000 * 60)) / 1000);

        document.getElementById('days')!.textContent = String(days).padStart(2, '0');
        document.getElementById('hours')!.textContent = String(hours).padStart(2, '0');
        document.getElementById('minutes')!.textContent = String(minutes).padStart(2, '0');
        document.getElementById('seconds')!.textContent = String(seconds).padStart(2, '0');
    }

    updateTimer();
    setInterval(updateTimer, 1000);
</script>