---
import { invitation } from "../data/invitation";
---

<section id="itinerario" class="w-full py-16 px-4 bg-[linear-gradient(135deg,#f5ead4_0%,#ecdfc4_50%,#e8d8b8_100%)]">
  <div class="max-w-2xl mx-auto flex flex-col items-center relative">
    <h2 class="font-script text-pooh-brown-dark text-[clamp(3rem,8vw,5rem)] text-center m-0 leading-none mb-10">Itinerario</h2>
    <img src="tree.png" alt="" aria-hidden="true" class="w-auto opacity-90 absolute h-96 bottom-0 right-0" />

    <ol class="w-full max-w-md m-0 p-0 list-none flex flex-col gap-6 z-20">
      {
        invitation.itinerary.map((item, i) => (
          <li class="flex gap-4 items-start">
            <div class="flex flex-col items-center pt-1.5 shrink-0">
              <div class="w-3 h-3 rounded-full bg-pooh-brown" />
              {i < invitation.itinerary.length - 1 && <div class="w-px flex-1 bg-pooh-brown-light mt-1 mb-1 min-h-12" />}
            </div>
            <div class="flex-1 pb-10 last:pb-0">
              <p class="font-serif text-pooh-brown font-semibold text-base tracking-[0.1em] m-0 uppercase">{item.time}</p>
              <p class="font-serif text-pooh-brown-dark text-2xl font-semibold m-0 mt-0.5">{item.title}</p>
              {item.description && <p class="font-serif text-pooh-brown italic text-base m-0 mt-1">{item.description}</p>}
            </div>
          </li>
        ))
      }
    </ol>
  </div>
</section>
