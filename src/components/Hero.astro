---
import Countdown from "./Countdown.astro";
import { hero, decorations, audio } from "../data/site.js";
---

<div class="hero">
  <div class="hero-pattern" aria-hidden="true"></div>

  <div class="decor-layer" aria-hidden="true">
    {
      decorations.map((item) => (
        <img
          class="decor-item"
          src={item.src}
          alt=""
          width={item.w}
          style={`left:${item.x}; top:${item.y}; width:${item.w}px; transform:rotate(${item.rot}deg); animation-delay:${item.delay}; animation-duration:${item.duration}; opacity:${item.opacity};`}
        />
      ))
    }
  </div>

  <div class="hero-content">
    <div class="title-block">
      <p
        class="eyebrow"
        data-aos="fade-down"
        data-aos-delay="100"
        data-aos-duration="600"
      >
        <span class="eyebrow-star">✦</span>
        {hero.eyebrow.text}
        <span class="eyebrow-star">✦</span>
      </p>

      <h1
        class="title"
        data-aos="fade-up"
        data-aos-delay="200"
        data-aos-duration="700"
      >
        {hero.title.line1}
        <span class="title-amp">&</span>
        <span class="title-accent">{hero.title.line2}</span>
      </h1>
    </div>

    <div
      class="photo-wrapper"
      data-aos="zoom-in"
      data-aos-delay="350"
      data-aos-duration="800"
      data-aos-offset="0"
    >
      <div class="photo-frame">
        <img src={hero.photo.src} alt={hero.photo.alt} class="photo" />
      </div>
    </div>

    <div
      class="actions"
      data-aos="fade-up"
      data-aos-delay="550"
      data-aos-duration="600"
    >
      {
        hero.buttons.map((btn) => (
          <a
            id={`btn-${btn.id}`}
            href={btn.href}
            target="_blank"
            rel="noopener noreferrer"
            class={`btn btn-${btn.type}`}
          >
            <span class="mt-1">{btn.text}</span>
          </a>
        ))
      }
    </div>

    <Countdown />
  </div>

  <audio id="bg-audio" src={audio.src} loop preload="none"></audio>

  <button
    id="confetti-btn"
    class="confetti-btn"
    aria-label="Celebrar con confeti"
    type="button"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="1em"
      height="1em"
      viewBox="0 0 24 24"
    >
      <path d="M0 0h24v24H0z" fill="none"></path>
      <path
        fill="currentColor"
        d="M16.83 7.17c-.1-.1-.21-.2-.32-.3c.3-.51.49-1.12.49-1.87c0-2.93-2.39-4-4-4v2c.46 0 2 .17 2 2c0 .18-.03.33-.07.48c-1.1-.89-2.21-1.63-3.24-2.13c-2.49-1.19-3.76-.69-4.39-.06c-.17.17-.32.38-.44.65s-.04.11-.04.11c-.04.1-.07.2-.1.31L2.49 17.34a3.27 3.27 0 0 0 .81 3.36c.63.63 1.47.97 2.33.97c.34 0 .69-.05 1.03-.16l13.14-4.28c.08-.03.17-.05.25-.08h.02c.27-.12.48-.27.65-.44c.63-.63 1.13-1.9-.06-4.39a15.6 15.6 0 0 0-1.47-2.41c.76-.52 1.7-.91 2.83-.91V7c-1.67 0-3.03.59-4.08 1.34c-.35-.39-.71-.78-1.09-1.17Zm-4.98 10c-.42-.2-.89-.49-1.36-.84c-.51-.38-1.02-.82-1.51-1.31s-.93-.99-1.31-1.51a9 9 0 0 1-.84-1.36c-.18-.38-.26-.64-.29-.81l1.05-3.23c.8 1.52 2.04 3.17 3.58 4.71s3.19 2.78 4.71 3.58l-3.23 1.05c-.16-.03-.43-.1-.81-.29Zm-5.81 2.44a1.31 1.31 0 0 1-1.65-1.65l1.26-3.87c.13.2.26.4.41.61c.44.59.94 1.17 1.5 1.73s1.14 1.06 1.73 1.5c.21.15.41.28.61.41L6.03 19.6Zm13.26-4.32s-.01 0-.02.01l-.16.05c-.3.04-.94-.04-1.94-.51c-1.43-.68-3.06-1.9-4.59-3.43S9.85 8.25 9.16 6.82c-.48-1-.56-1.64-.51-1.94l.05-.16s0-.02.01-.02c.04-.04.15-.07.33-.07c.34 0 .93.12 1.79.52c.8.38 1.67.95 2.55 1.63c-.68.2-1.32.21-1.37.21v2c.84 0 2.03-.2 3.05-.76c.12.12.25.22.37.34c.36.36.7.72 1.02 1.09c-.85.95-1.29 1.8-1.33 1.88l1.79.89s.28-.54.8-1.17c.46.65.86 1.29 1.15 1.9c.62 1.3.57 2 .45 2.12Z"
      ></path>
    </svg>
  </button>

  <button
    id="audio-toggle"
    class="audio-btn"
    aria-label="Reproducir o pausar música"
    type="button"
  >
    <svg class="audio-icon-play" viewBox="0 0 24 24" fill="currentColor">
      <path d="M8 5v14l11-7z"></path>
    </svg>
    <svg class="audio-icon-pause" viewBox="0 0 24 24" fill="currentColor">
      <rect x="6" y="5" width="4" height="14" rx="1"></rect>
      <rect x="14" y="5" width="4" height="14" rx="1"></rect>
    </svg>
  </button>
</div>

<style>
  .hero {
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding: 2.5rem 1rem 3rem;
    position: relative;
    overflow: hidden;
  }

  .hero-pattern {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(
      circle,
      rgba(255, 107, 157, 0.07) 1.2px,
      transparent 1.2px
    );
    background-size: 28px 28px;
    z-index: 0;
    pointer-events: none;
  }

  .decor-layer {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
  }

  .decor-item {
    position: absolute;
    animation-name: float-gentle;
    animation-iteration-count: infinite;
    animation-timing-function: ease-in-out;
    user-select: none;
  }

  @keyframes float-gentle {
    0%,
    100% {
      translate: 0 0;
    }
    50% {
      translate: 0 -18px;
    }
  }

  .audio-btn {
    position: fixed;
    bottom: 1.25rem;
    right: 1.25rem;
    z-index: 100;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    border: none;
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    box-shadow: 0 4px 16px rgba(255, 107, 157, 0.3);
    cursor: pointer;
    display: grid;
    place-items: center;
    color: var(--color-primary-dark);
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease;
  }

  .audio-btn:hover {
    transform: scale(1.08);
    box-shadow: 0 6px 20px rgba(255, 107, 157, 0.4);
  }

  .audio-btn:active {
    transform: scale(0.95);
  }

  .audio-btn svg {
    width: 22px;
    height: 22px;
  }

  .audio-icon-pause {
    display: none;
  }
  .audio-btn.is-playing .audio-icon-play {
    display: none;
  }
  .audio-btn.is-playing .audio-icon-pause {
    display: block;
  }

  .confetti-btn {
    position: fixed;
    bottom: 1.25rem;
    left: 1.25rem;
    z-index: 100;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    border: none;
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    box-shadow: 0 4px 16px rgba(255, 107, 157, 0.3);
    cursor: pointer;
    display: grid;
    place-items: center;
    color: var(--color-primary-dark);
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease;
  }

  .confetti-btn:hover {
    transform: scale(1.08) rotate(-8deg);
    box-shadow: 0 6px 20px rgba(255, 107, 157, 0.4);
  }

  .confetti-btn:active {
    transform: scale(0.95);
  }

  .confetti-btn svg {
    width: 24px;
    height: 24px;
  }

  .hero-content {
    position: relative;
    z-index: 10;
    display: grid;
    place-items: center;
    gap: 1.5rem;
    width: 100%;
    max-width: 500px;
  }

  @media (min-width: 768px) {
    .hero {
      padding: 3rem 1.5rem 4rem;
    }
    .hero-content {
      max-width: 540px;
      gap: 1.75rem;
    }
  }

  @media (min-width: 1024px) {
    .hero {
      padding: 4rem 2rem 5rem;
    }
    .hero-content {
      max-width: 580px;
    }
  }

  .title-block {
    text-align: center;
    display: grid;
    gap: 0.75rem;
    width: 100%;
  }

  .eyebrow {
    margin: 0;
    font-size: 0.85rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: #b0305a;
    font-weight: 600;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    text-shadow: 0 1px 3px rgba(255, 255, 255, 0.8);
  }

  .eyebrow-star {
    color: #c2780a;
    font-size: 0.7rem;
  }

  .title {
    margin: 0;
    font-size: clamp(2.2rem, 6.5vw, 3.8rem);
    line-height: 1;
    font-weight: 700;
    color: #3a2222;
    text-transform: uppercase;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.15rem;
    text-shadow:
      0 2px 8px rgba(255, 255, 255, 0.75),
      0 1px 2px rgba(255, 255, 255, 0.9);
  }

  .title-amp {
    font-size: 0.5em;
    font-weight: 300;
    color: var(--color-primary);
    font-style: italic;
    margin: 0.2rem 0;
  }

  .title-accent {
    color: var(--color-primary-dark);
  }

  .meta-row {
    display: inline-flex;
    align-items: center;
    gap: 0.85rem;
    background: rgba(255, 255, 255, 0.7);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.8);
    border-radius: 999px;
    padding: 0.55rem 1.2rem;
    margin: 0.4rem auto 0;
    box-shadow: 0 4px 20px rgba(255, 107, 157, 0.1);
    flex-wrap: wrap;
    justify-content: center;
  }

  .meta-item {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--color-text);
    font-size: 1rem;
    font-weight: 500;
    letter-spacing: 0.04em;
  }

  .meta-icon {
    width: 16px;
    height: 16px;
    color: var(--color-primary);
  }

  .meta-divider {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--color-primary);
    opacity: 0.5;
  }

  .photo-wrapper {
    position: relative;
    display: grid;
    place-items: center;
    margin: 0.25rem 0;
  }

  .photo-frame {
    position: relative;
    width: 260px;
    height: 260px;
    border-radius: 50%;
    padding: 5px;
    background: linear-gradient(
      135deg,
      var(--color-primary),
      var(--color-accent)
    );
    box-shadow:
      0 0 0 5px rgba(255, 255, 255, 0.5),
      0 10px 30px rgba(255, 107, 157, 0.3);
  }

  @media (min-width: 768px) {
    .photo-frame {
      width: 240px;
      height: 240px;
    }
  }

  @media (min-width: 1024px) {
    .photo-frame {
      width: 280px;
      height: 280px;
    }
  }

  .photo {
    width: 100%;
    height: 100%;
    object-fit: contain;
    border-radius: 50%;
    border: 3px solid white;
    display: block;
  }

  .actions {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: 0.25rem;
    justify-items: center;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.85rem 1.5rem;
    border-radius: 1rem;
    font-weight: 800;
    font-size: 1rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    text-decoration: none;
    color: white;
    transition:
      transform 0.15s ease,
      background-color 0.2s ease;
    cursor: pointer;
    border: 0;
    border-bottom-width: 5px;
    border-bottom-style: solid;
  }

  @media (min-width: 768px) {
    .btn {
      font-size: 1.1rem;
      padding: 0.95rem 1.75rem;
    }
  }

  .btn:hover {
    transform: translateY(-1px);
  }
  .btn:active {
    transform: translateY(4px);
    border-bottom-width: 0;
  }

  .btn-icon {
    width: 18px;
    height: 18px;
  }

  .btn-primary {
    background-color: #f472b6;
    border-bottom-color: #db2777;
  }
  .btn-primary:hover {
    background-color: #ec4899;
  }

  .btn-secondary {
    background-color: #38bdf8;
    border-bottom-color: #0284c7;
  }
  .btn-secondary:hover {
    background-color: #0ea5e9;
  }
</style>

<script>
  import AOS from "aos";
  import "aos/dist/aos.css";
  import confetti from "canvas-confetti";
  import { confetti as confettiData } from "../data/site.js";

  AOS.init({ once: true });

  const colors = confettiData.colors;

  const audio = document.getElementById("bg-audio") as HTMLAudioElement | null;
  const audioBtn = document.getElementById("audio-toggle");

  if (audio && audioBtn) {
    audio.volume = 0.5;

    audioBtn.addEventListener("click", (e) => {
      e.stopPropagation();
      if (audio!.paused) {
        audio!.play();
        audioBtn!.classList.add("is-playing");
      } else {
        audio!.pause();
        audioBtn!.classList.remove("is-playing");
      }
    });
  }

  const confettiBtn = document.getElementById("confetti-btn");
  if (confettiBtn) {
    confettiBtn.addEventListener("click", (e) => {
      e.stopPropagation();
      confetti({ particleCount: 120, spread: 90, origin: { y: 0.5 }, colors });
      setTimeout(() => {
        confetti({
          particleCount: 60,
          angle: 60,
          spread: 55,
          origin: { x: 0, y: 0.7 },
          colors,
        });
        confetti({
          particleCount: 60,
          angle: 120,
          spread: 55,
          origin: { x: 1, y: 0.7 },
          colors,
        });
      }, 250);
    });
  }

  window.addEventListener("load", () => {
    setTimeout(() => {
      confetti({ particleCount: 80, spread: 70, origin: { y: 0.5 }, colors });
    }, 600);
  });

  let scrollCooldown = false;
  const burst = () => {
    if (scrollCooldown) return;
    scrollCooldown = true;
    confetti({ particleCount: 35, spread: 60, origin: { y: 0.8 }, colors });
    setTimeout(() => {
      scrollCooldown = false;
    }, 1200);
  };

  window.addEventListener("wheel", burst);

  let touchStartY = 0;
  window.addEventListener("touchstart", (e) => {
    touchStartY = e.touches[0].clientY;
  });
  window.addEventListener("touchmove", (e) => {
    if (e.touches[0].clientY - touchStartY < -20) burst();
  });
</script>
