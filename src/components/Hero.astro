---
import Countdown from './Countdown.astro';
---

<div class="hero relative w-full overflow-hidden">
    <div id="confetti-dots" aria-hidden="true" class="confetti-layer"></div>

    <div class="hero-content">
        <div class="photo-wrapper" data-aos="zoom-in" data-aos-duration="800" data-aos-offset="0">
            <div class="photo-ring"></div>
            <div class="photo-glow"></div>
            <img src="/emi1.webp" alt="Emiliano" class="photo" />
            <span class="sparkle sparkle-1">✦</span>
            <span class="sparkle sparkle-2">✦</span>
            <span class="sparkle sparkle-3">✦</span>
        </div>

        <div class="title-block">
            <p class="eyebrow" data-aos="fade-down" data-aos-delay="200" data-aos-duration="600">
                Te invitamos a celebrar
            </p>

            <h1 class="title" data-aos="fade-up" data-aos-delay="350" data-aos-duration="700">
                Mi primer añito
                <span class="title-amp">&</span>
                <span class="title-accent">bautizo</span>
            </h1>

            <div class="meta-row" data-aos="fade-up" data-aos-delay="550" data-aos-duration="600">
                <div class="meta-item">
                    <svg class="meta-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="4" width="18" height="18" rx="2" />
                        <line x1="16" y1="2" x2="16" y2="6" />
                        <line x1="8" y1="2" x2="8" y2="6" />
                        <line x1="3" y1="10" x2="21" y2="10" />
                    </svg>
                    <span>26 · Julio · 2026</span>
                </div>
                <span class="meta-divider"></span>
                <div class="meta-item">
                    <svg class="meta-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10" />
                        <polyline points="12 6 12 12 16 14" />
                    </svg>
                    <span>2:30 PM</span>
                </div>
            </div>

            <div class="actions" data-aos="fade-up" data-aos-delay="700" data-aos-duration="600">
                <a id="btn-confirmar"
                    href="https://wa.me/5213322331626?text=Hola!%20Confirmo%20mi%20asistencia%20al%20primer%20añito%20de%20Emiliano.%20Ahi%20estare!"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="btn btn-primary">
                    <svg viewBox="0 0 24 24" fill="currentColor" class="btn-icon">
                        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
                    </svg>
                    <span>Confirmar</span>
                </a>
                <a href="https://calendar.app.google/vD1dW3ebxsUHCoQg6"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="btn btn-secondary">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="btn-icon">
                        <rect x="3" y="4" width="18" height="18" rx="2" />
                        <line x1="16" y1="2" x2="16" y2="6" />
                        <line x1="8" y1="2" x2="8" y2="6" />
                        <line x1="3" y1="10" x2="21" y2="10" />
                        <polyline points="9 16 11 18 15 14" />
                    </svg>
                    <span>Ver evento</span>
                </a>
            </div>
        </div>

        <Countdown />
    </div>

    <img src="/emi3.webp" alt="" class="deco deco-left animate-float-slower" aria-hidden="true"
        data-aos="fade-right" data-aos-delay="800" data-aos-duration="600" data-aos-offset="0" />
    <img src="/emi3.webp" alt="" class="deco deco-right animate-float-slow" aria-hidden="true"
        data-aos="fade-left" data-aos-delay="800" data-aos-duration="600" data-aos-offset="0" />
</div>

<style>
    .hero {
        min-height: 100dvh;
        background-image: url("/hero-mobile.webp");
        background-size: cover;
        background-position: center top;
        background-repeat: no-repeat;
        display: grid;
        place-items: center;
        padding: 1.5rem 1rem 2rem;
    }

    @media (min-width: 1024px) {
        .hero {
            background-image: url("/hero-desktop.webp");
            background-size: cover;
            background-position: center;
        }
    }

    .confetti-layer {
        position: absolute;
        inset: 0;
        pointer-events: none;
        z-index: 0;
        overflow: hidden;
    }

    .hero-content {
        position: relative;
        z-index: 10;
        display: grid;
        place-items: center;
        gap: 1.25rem;
        width: 100%;
        max-width: 640px;
    }

    .photo-wrapper {
        position: relative;
        width: 180px;
        height: 180px;
        display: grid;
        place-items: center;
    }

    @media (min-width: 768px) {
        .photo-wrapper { width: 220px; height: 220px; }
    }

    .photo-ring {
        position: absolute;
        inset: -8px;
        border-radius: 50%;
        background: conic-gradient(from 0deg, var(--color-primary), var(--color-accent), var(--color-secondary), var(--color-primary));
        padding: 6px;
        animation: spin 14s linear infinite;
    }

    .photo-ring::after {
        content: '';
        position: absolute;
        inset: 6px;
        border-radius: 50%;
        background: var(--color-background);
    }

    @keyframes spin {
        to { transform: rotate(360deg); }
    }

    .photo-glow {
        position: absolute;
        inset: -30px;
        background: radial-gradient(circle, rgba(255, 107, 157, 0.35) 0%, transparent 60%);
        z-index: -1;
        filter: blur(10px);
    }

    .photo {
        position: relative;
        z-index: 2;
        width: 92%;
        height: 92%;
        object-fit: cover;
        border-radius: 50%;
    }

    .sparkle {
        position: absolute;
        color: var(--color-accent);
        font-size: 1.5rem;
        z-index: 3;
        text-shadow: 0 0 10px rgba(255, 209, 102, 0.6);
        animation: twinkle 2.5s ease-in-out infinite;
    }

    .sparkle-1 { top: 4%; left: 8%; animation-delay: 0s; }
    .sparkle-2 { top: 12%; right: 4%; animation-delay: 0.8s; font-size: 1.2rem; }
    .sparkle-3 { bottom: 8%; left: 14%; animation-delay: 1.5s; font-size: 1rem; }

    @keyframes twinkle {
        0%, 100% { opacity: 0.4; transform: scale(0.9) rotate(0deg); }
        50% { opacity: 1; transform: scale(1.2) rotate(15deg); }
    }

    .title-block {
        text-align: center;
        display: grid;
        gap: 0.75rem;
        width: 100%;
    }

    .eyebrow {
        margin: 0;
        font-size: 0.95rem;
        letter-spacing: 0.25em;
        text-transform: uppercase;
        color: var(--color-primary-dark);
        font-weight: 500;
    }

    .title {
        margin: 0;
        font-size: clamp(2.2rem, 7vw, 4rem);
        line-height: 1;
        font-weight: 700;
        color: var(--color-text);
        text-transform: uppercase;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.15rem;
        text-shadow: 2px 2px 0 rgba(255, 255, 255, 0.6);
    }

    .title-amp {
        font-size: 0.5em;
        font-weight: 300;
        color: var(--color-primary);
        font-style: italic;
        margin: 0.2rem 0;
    }

    .title-accent {
        background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-accent) 100%);
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
        color: transparent;
    }

    .meta-row {
        display: inline-flex;
        align-items: center;
        gap: 0.85rem;
        background: rgba(255, 255, 255, 0.75);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid rgba(255, 255, 255, 0.8);
        border-radius: 999px;
        padding: 0.55rem 1.2rem;
        margin: 0.4rem auto 0.2rem;
        box-shadow: 0 4px 20px rgba(255, 107, 157, 0.12);
        flex-wrap: wrap;
        justify-content: center;
    }

    .meta-item {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        color: var(--color-text);
        font-size: 1.05rem;
        font-weight: 500;
        letter-spacing: 0.04em;
    }

    .meta-icon {
        width: 18px;
        height: 18px;
        color: var(--color-primary);
    }

    .meta-divider {
        width: 4px;
        height: 4px;
        border-radius: 50%;
        background: var(--color-primary);
        opacity: 0.5;
    }

    .actions {
        display: flex;
        gap: 0.75rem;
        justify-content: center;
        flex-wrap: wrap;
        margin-top: 0.5rem;
    }

    .btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.85rem 1.5rem;
        border-radius: 999px;
        font-weight: 600;
        font-size: 1rem;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        text-decoration: none;
        color: white;
        transition: transform 0.2s ease, box-shadow 0.2s ease, filter 0.2s ease;
        position: relative;
        overflow: hidden;
        cursor: pointer;
    }

    .btn::before {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.2) 0%, transparent 50%);
        pointer-events: none;
    }

    .btn:hover {
        transform: translateY(-2px);
        filter: brightness(1.05);
    }

    .btn:active {
        transform: translateY(0);
    }

    .btn-icon {
        width: 20px;
        height: 20px;
        position: relative;
        z-index: 1;
    }

    .btn-primary {
        background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
        box-shadow:
            0 4px 0 rgba(178, 60, 110, 1),
            0 8px 20px rgba(255, 107, 157, 0.4);
    }

    .btn-primary:hover {
        box-shadow:
            0 6px 0 rgba(178, 60, 110, 1),
            0 12px 28px rgba(255, 107, 157, 0.5);
    }

    .btn-primary:active {
        box-shadow:
            0 2px 0 rgba(178, 60, 110, 1),
            0 4px 12px rgba(255, 107, 157, 0.4);
    }

    .btn-secondary {
        background: linear-gradient(135deg, var(--color-secondary) 0%, #3aa8a0 100%);
        box-shadow:
            0 4px 0 rgba(48, 130, 124, 1),
            0 8px 20px rgba(78, 205, 196, 0.35);
    }

    .btn-secondary:hover {
        box-shadow:
            0 6px 0 rgba(48, 130, 124, 1),
            0 12px 28px rgba(78, 205, 196, 0.45);
    }

    .btn-secondary:active {
        box-shadow:
            0 2px 0 rgba(48, 130, 124, 1),
            0 4px 12px rgba(78, 205, 196, 0.35);
    }

    .deco {
        position: absolute;
        bottom: 0.5rem;
        width: 120px;
        pointer-events: none;
        z-index: 5;
    }

    @media (min-width: 768px) {
        .deco { width: 150px; }
    }

    .deco-left { left: 0.5rem; transform: scaleX(-1); }
    .deco-right { right: 0.5rem; }

    @media (max-width: 640px) {
        .deco { display: none; }
    }
</style>

<script>
    import AOS from 'aos';
    import 'aos/dist/aos.css';
    import confetti from 'canvas-confetti';

    AOS.init({ once: true });

    const colors = ['#ff6b9d', '#ffd166', '#4ecdc4', '#a78bfa', '#fb923c', '#60a5fa', '#34d399', '#f472b6'];
    const container = document.getElementById('confetti-dots');
    if (container) {
        for (let i = 0; i < 45; i++) {
            const dot = document.createElement('span');
            const size = Math.random() * 8 + 4;
            dot.style.cssText = `
                position: absolute; border-radius: 50%;
                width: ${size}px; height: ${size}px;
                background: ${colors[Math.floor(Math.random() * colors.length)]};
                opacity: ${Math.random() * 0.4 + 0.3};
                top: ${Math.random() * 100}%; left: ${Math.random() * 100}%;
                filter: blur(${Math.random() > 0.5 ? '1px' : '0'});
            `;
            container.appendChild(dot);
        }
    }

    window.addEventListener('load', () => {
        setTimeout(() => {
            confetti({ particleCount: 150, spread: 90, origin: { y: 0.55 }, colors });
            setTimeout(() => {
                confetti({ particleCount: 80, angle: 60, spread: 55, origin: { x: 0, y: 0.7 }, colors });
                confetti({ particleCount: 80, angle: 120, spread: 55, origin: { x: 1, y: 0.7 }, colors });
            }, 300);
        }, 500);
    });

    let scrollCooldown = false;
    const burst = () => {
        if (scrollCooldown) return;
        scrollCooldown = true;
        confetti({ particleCount: 60, spread: 70, origin: { y: 0.85 }, colors });
        setTimeout(() => { scrollCooldown = false; }, 800);
    };

    window.addEventListener('wheel', burst);

    let touchStartY = 0;
    window.addEventListener('touchstart', (e) => { touchStartY = e.touches[0].clientY; });
    window.addEventListener('touchmove', (e) => {
        if (e.touches[0].clientY - touchStartY < -20) burst();
    });
</script>
