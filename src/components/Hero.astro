</div>

<style>
    .hero {
        min-height: 100dvh;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        padding: 2.5rem 1rem 3rem;
        position: relative;
        overflow: hidden;
    }

    .hero-pattern {
        position: absolute;
        inset: 0;
        background-image: radial-gradient(circle, rgba(255, 107, 157, 0.07) 1.2px, transparent 1.2px);
        background-size: 28px 28px;
        z-index: 0;
        pointer-events: none;
    }

    .decor-layer {
        position: absolute;
        inset: 0;
        z-index: 1;
        pointer-events: none;
    }

    .decor-item {
        position: absolute;
        animation-name: float-gentle;
        animation-iteration-count: infinite;
        animation-timing-function: ease-in-out;
        user-select: none;
    }

    @keyframes float-gentle {
        0%, 100% { translate: 0 0; }
        50%      { translate: 0 -18px; }
    }

    .audio-btn {
        position: fixed;
        bottom: 1.25rem;
        right: 1.25rem;
        z-index: 100;
        width: 48px;
        height: 48px;
        border-radius: 50%;
        border: none;
        background: rgba(255, 255, 255, 0.85);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        box-shadow: 0 4px 16px rgba(255, 107, 157, 0.3);
        cursor: pointer;
        display: grid;
        place-items: center;
        color: var(--color-primary-dark);
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .audio-btn:hover {
        transform: scale(1.08);
        box-shadow: 0 6px 20px rgba(255, 107, 157, 0.4);
    }

    .audio-btn:active {
        transform: scale(0.95);
    }

    .audio-btn svg {
        width: 22px;
        height: 22px;
    }

    .audio-icon-pause { display: none; }
    .audio-btn.is-playing .audio-icon-play { display: none; }
    .audio-btn.is-playing .audio-icon-pause { display: block; }

    .hero-content {
        position: relative;
        z-index: 10;
        display: grid;
        place-items: center;
        gap: 1.5rem;
        width: 100%;
        max-width: 500px;
    }

    @media (min-width: 768px) {
        .hero { padding: 3rem 1.5rem 4rem; }
        .hero-content { max-width: 540px; gap: 1.75rem; }
    }

    @media (min-width: 1024px) {
        .hero { padding: 4rem 2rem 5rem; }
        .hero-content { max-width: 580px; }
    }

    .title-block {
        text-align: center;
        display: grid;
        gap: 0.75rem;
        width: 100%;
    }

    .eyebrow {
        margin: 0;
        font-size: 0.85rem;
        letter-spacing: 0.3em;
        text-transform: uppercase;
        color: #b0305a;
        font-weight: 600;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
        text-shadow: 0 1px 3px rgba(255, 255, 255, 0.8);
    }

    .eyebrow-star {
        color: #c2780a;
        font-size: 0.7rem;
    }

    .title {
        margin: 0;
        font-size: clamp(2.2rem, 6.5vw, 3.8rem);
        line-height: 1;
        font-weight: 700;
        color: #3a2222;
        text-transform: uppercase;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.15rem;
        text-shadow:
            0 2px 8px rgba(255, 255, 255, 0.75),
            0 1px 2px rgba(255, 255, 255, 0.9);
    }

    .title-amp {
        font-size: 0.5em;
        font-weight: 300;
        color: var(--color-primary);
        font-style: italic;
        margin: 0.2rem 0;
    }

    .title-accent {
        color: var(--color-primary-dark);
    }

    .meta-row {
        display: inline-flex;
        align-items: center;
        gap: 0.85rem;
        background: rgba(255, 255, 255, 0.7);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid rgba(255, 255, 255, 0.8);
        border-radius: 999px;
        padding: 0.55rem 1.2rem;
        margin: 0.4rem auto 0;
        box-shadow: 0 4px 20px rgba(255, 107, 157, 0.1);
        flex-wrap: wrap;
        justify-content: center;
    }

    .meta-item {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        color: var(--color-text);
        font-size: 1rem;
        font-weight: 500;
        letter-spacing: 0.04em;
    }

    .meta-icon {
        width: 16px;
        height: 16px;
        color: var(--color-primary);
    }

    .meta-divider {
        width: 4px;
        height: 4px;
        border-radius: 50%;
        background: var(--color-primary);
        opacity: 0.5;
    }

    .photo-wrapper {
        position: relative;
        display: grid;
        place-items: center;
        margin: 0.25rem 0;
    }

    .photo-frame {
        position: relative;
        width: 260px;
        height: 260px;
        border-radius: 50%;
        padding: 5px;
        background: linear-gradient(135deg, var(--color-primary), var(--color-accent));
        box-shadow:
            0 0 0 5px rgba(255, 255, 255, 0.5),
            0 10px 30px rgba(255, 107, 157, 0.3);
    }

    @media (min-width: 768px) {
        .photo-frame { width: 240px; height: 240px; }
    }

    @media (min-width: 1024px) {
        .photo-frame { width: 280px; height: 280px; }
    }

    .photo {
        width: 100%;
        height: 100%;
        object-fit: contain;
        border-radius: 50%;
        border: 3px solid white;
        display: block;
    }



    .actions {
        display: flex;
        gap: 0.75rem;
        justify-content: center;
        flex-wrap: wrap;
        margin-top: 0.25rem;
        justify-items: center;
    }

    .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        padding: 0.85rem 1.5rem;
        border-radius: 1rem;
        font-weight: 800;
        font-size: 1rem;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        text-decoration: none;
        color: white;
        transition: transform 0.15s ease, background-color 0.2s ease;
        cursor: pointer;
        border: 0;
        border-bottom-width: 5px;
        border-bottom-style: solid;
    }

    @media (min-width: 768px) {
        .btn { font-size: 1.1rem; padding: 0.95rem 1.75rem; }
    }

    .btn:hover  { transform: translateY(-1px); }
    .btn:active {
        transform: translateY(4px);
        border-bottom-width: 0;
    }

    .btn-icon { width: 18px; height: 18px; }

    .btn-primary {
        background-color: #f472b6;
        border-bottom-color: #db2777;
    }
    .btn-primary:hover { background-color: #ec4899; }

    .btn-secondary {
        background-color: #38bdf8;
        border-bottom-color: #0284c7;
    }
    .btn-secondary:hover { background-color: #0ea5e9; }
</style>

<script>
    import AOS from 'aos';
    import 'aos/dist/aos.css';
    import confetti from 'canvas-confetti';

    AOS.init({ once: true });

    const colors = ['#ff6b9d', '#ffd166', '#4ecdc4', '#a78bfa', '#fb923c'];

    const audio = document.getElementById('bg-audio') as HTMLAudioElement | null;
    const audioBtn = document.getElementById('audio-toggle');

    if (audio && audioBtn) {
        audio.volume = 0.5;

        const tryAutoplay = () => {
            audio!.play().then(() => {
                audioBtn!.classList.add('is-playing');
            }).catch(() => {});
        };

        tryAutoplay();
        document.addEventListener('click', tryAutoplay, { once: true });
        document.addEventListener('touchstart', tryAutoplay, { once: true });

        audioBtn.addEventListener('click', (e) => {
            e.stopPropagation();
            if (audio!.paused) {
                audio!.play();
                audioBtn!.classList.add('is-playing');
            } else {
                audio!.pause();
                audioBtn!.classList.remove('is-playing');
            }
        });
    }

    window.addEventListener('load', () => {
        setTimeout(() => {
            confetti({ particleCount: 80, spread: 70, origin: { y: 0.5 }, colors });
        }, 600);
    });

    let scrollCooldown = false;
    const burst = () => {
        if (scrollCooldown) return;
        scrollCooldown = true;
        confetti({ particleCount: 35, spread: 60, origin: { y: 0.8 }, colors });
        setTimeout(() => { scrollCooldown = false; }, 1200);
    };

    window.addEventListener('wheel', burst);

    let touchStartY = 0;
    window.addEventListener('touchstart', (e) => { touchStartY = e.touches[0].clientY; });
    window.addEventListener('touchmove', (e) => {
        if (e.touches[0].clientY - touchStartY < -20) burst();
    });
</script>
