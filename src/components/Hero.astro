---
import { invitation } from "../data/invitation";
---

<main class="invitation">
  <div class="content">
    <h1 class="name">{invitation.name}</h1>
    <p class="subtitle">{invitation.subtitle.toUpperCase()}</p>

    <div class="illustration">
      <img src={invitation.heroImage} alt={`${invitation.name} - ilustración`} />
    </div>

    <p class="invite-text">{invitation.inviteText}</p>

    <div class="date-row">
      <div class="date-cell">
        <span class="date-line"></span>
        <span class="date-label">{invitation.date.month}</span>
        <span class="date-line"></span>
      </div>
      <div class="date-circle">
        <span>{invitation.date.day}</span>
      </div>
      <div class="date-cell">
        <span class="date-line"></span>
        <span class="date-label">{invitation.date.time}</span>
        <span class="date-line"></span>
      </div>
    </div>

    <div class="location">
      <div class="location-header">
        <svg class="pin" viewBox="0 0 24 24" aria-hidden="true">
          <path
            d="M12 2 C7.58 2 4 5.58 4 10 c0 5.25 7 12 8 12 s8-6.75 8-12 c0-4.42-3.58-8-8-8 z"
            fill="none"
            stroke="#6b4423"
            stroke-width="1.4"></path>
          <circle cx="12" cy="10" r="2.5" fill="none" stroke="#6b4423" stroke-width="1.4"></circle>
        </svg>
        <span>{invitation.location.label}</span>
      </div>
      <p class="location-text">{invitation.location.address}</p>
    </div>
  </div>
</main>

<style>
  .invitation {
    position: relative;
    width: 100vw;
    height: 100vh;
    height: 100svh;
    background: linear-gradient(135deg, #f5ead4 0%, #ecdfc4 50%, #e8d8b8 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    width: 100%;
    max-width: 540px;
    padding: 1.5rem 1rem;
    gap: 0.4rem;
  }

  .name {
    font-family: "Pinyon Script", cursive;
    color: #5a3a20;
    font-size: clamp(4.5rem, 11vw, 7.5rem);
    line-height: 1;
    margin: 0;
    font-weight: 400;
    text-shadow: 1px 1px 0 rgba(0, 0, 0, 0.05);
  }

  .subtitle {
    font-family: "Cormorant Garamond", serif;
    color: #6b4423;
    font-size: clamp(1.1rem, 2.6vw, 1.65rem);
    letter-spacing: 0.25em;
    margin: 0 0 0.5rem 0;
    font-weight: 500;
  }

  .illustration {
    width: clamp(260px, 55vw, 380px);
    margin: 0.3rem 0;
  }

  .illustration img {
    width: 100%;
    height: auto;
    display: block;
  }

  .invite-text {
    font-family: "Cormorant Garamond", serif;
    color: #5a3a20;
    font-size: clamp(1.05rem, 2.4vw, 1.5rem);
    font-style: italic;
    margin: 0.5rem 0 0.3rem 0;
    font-weight: 500;
  }

  .date-row {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    max-width: 460px;
    margin: 0.3rem 0;
    gap: 0;
  }

  .date-cell {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex: 1;
    gap: 0.35rem;
  }

  .date-line {
    width: 100%;
    height: 1px;
    background-color: #8a5a35;
  }

  .date-label {
    font-family: "Cormorant Garamond", serif;
    color: #6b4423;
    font-size: clamp(1.2rem, 2.8vw, 1.55rem);
    letter-spacing: 0.1em;
    font-weight: 500;
    white-space: nowrap;
  }

  .date-circle {
    width: clamp(54px, 9vw, 68px);
    height: clamp(54px, 9vw, 68px);
    border-radius: 50%;
    background-color: #6b4423;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin: 0 0.5rem;
    line-height: 1;
  }

  .date-circle span {
    font-family: "Pinyon Script", cursive;
    color: #f5ead4;
    font-size: clamp(2.2rem, 5vw, 3rem);
    font-weight: 400;
    line-height: 1;
    padding-top: 0.35em;
  }

  .location {
    margin-top: 0.6rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.35rem;
  }

  .location-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: "Cormorant Garamond", serif;
    color: #6b4423;
    font-size: clamp(0.95rem, 2.1vw, 1.2rem);
    letter-spacing: 0.15em;
    font-weight: 600;
  }

  .pin {
    width: clamp(20px, 3vw, 26px);
    height: auto;
  }

  .location-text {
    font-family: "Cormorant Garamond", serif;
    color: #5a3a20;
    font-size: clamp(0.9rem, 2vw, 1.15rem);
    font-style: italic;
    font-weight: 500;
    margin: 0;
    max-width: 95%;
    line-height: 1.35;
  }

  @media (max-height: 700px) {
    .content {
      gap: 0.2rem;
      padding: 0.8rem;
    }
    .illustration {
      width: clamp(220px, 48vw, 320px);
    }
    .name {
      font-size: clamp(3.5rem, 9vw, 5.5rem);
    }
  }

  @media (max-width: 380px) {
    .name {
      font-size: 3.8rem;
    }
    .subtitle {
      letter-spacing: 0.15em;
    }
  }
</style>
