---
import Countdown from './Countdown.astro';

const floatItems = [
    { char: '★', x: '7%',  y: '14%', size: '1.4rem', color: 'var(--color-primary)',   delay: '0s',   duration: '6s'   },
    { char: '♥', x: '91%', y: '16%', size: '1.1rem', color: 'var(--color-accent)',    delay: '1.2s', duration: '7s'   },
    { char: '✦', x: '12%', y: '78%', size: '0.9rem', color: 'var(--color-secondary)', delay: '2s',   duration: '5.5s' },
    { char: '★', x: '87%', y: '74%', size: '1.2rem', color: 'var(--color-primary)',   delay: '0.6s', duration: '6.5s' },
    { char: '●', x: '20%', y: '38%', size: '0.5rem', color: 'var(--color-accent)',    delay: '1.5s', duration: '5s'   },
    { char: '♥', x: '80%', y: '42%', size: '0.8rem', color: 'var(--color-secondary)', delay: '2.8s', duration: '6.2s' },
    { char: '✦', x: '4%',  y: '52%', size: '0.7rem', color: 'var(--color-primary)',   delay: '3.2s', duration: '5.8s' },
    { char: '●', x: '96%', y: '56%', size: '0.4rem', color: 'var(--color-accent)',    delay: '1.8s', duration: '6.3s' },
];
---

<div class="hero">
    <div class="hero-pattern" aria-hidden="true"></div>

    <div class="float-layer" aria-hidden="true">
        {floatItems.map(item => (
            <span
                class="float-item"
                style={`left:${item.x}; top:${item.y}; font-size:${item.size}; color:${item.color}; animation-delay:${item.delay}; animation-duration:${item.duration};`}
            >{item.char}</span>
        ))}
    </div>

    <div class="hero-content">
        <div class="title-block">
            <p class="eyebrow" data-aos="fade-down" data-aos-delay="100" data-aos-duration="600">
                <span class="eyebrow-star">✦</span>
                Te invitamos a celebrar
                <span class="eyebrow-star">✦</span>
            </p>

            <h1 class="title" data-aos="fade-up" data-aos-delay="200" data-aos-duration="700">
                Mi primer añito
                <span class="title-amp">&</span>
                <span class="title-accent">bautizo</span>
            </h1>
        </div>

        <div class="photo-wrapper" data-aos="zoom-in" data-aos-delay="350" data-aos-duration="800" data-aos-offset="0">
            <div class="photo-frame">
                <img src="/emi1.webp" alt="Emiliano" class="photo" />
            </div>
        </div>

        <div class="actions" data-aos="fade-up" data-aos-delay="550" data-aos-duration="600">
            <a id="btn-confirmar"
                href="https://wa.me/5213322331626?text=Hola!%20Confirmo%20mi%20asistencia%20al%20primer%20añito%20de%20Emiliano.%20Ahi%20estare!"
                target="_blank"
                rel="noopener noreferrer"
                class="btn btn-primary">
                <svg viewBox="0 0 24 24" fill="currentColor" class="btn-icon">
                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
                </svg>
                <span>Confirmar</span>
            </a>
            <a href="https://calendar.app.google/vD1dW3ebxsUHCoQg6"
                target="_blank"
                rel="noopener noreferrer"
                class="btn btn-secondary">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="btn-icon">
                    <rect x="3" y="4" width="18" height="18" rx="2" />
                    <line x1="16" y1="2" x2="16" y2="6" />
                    <line x1="8" y1="2" x2="8" y2="6" />
                    <line x1="3" y1="10" x2="21" y2="10" />
                    <polyline points="9 16 11 18 15 14" />
                </svg>
                <span>Ver evento</span>
            </a>
        </div>

        <Countdown />
    </div>
</div>

<style>
    .hero {
        min-height: 100dvh;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        padding: 2.5rem 1rem 3rem;
        position: relative;
        overflow: hidden;
    }

    .hero-pattern {
        position: absolute;
        inset: 0;
        background-image: radial-gradient(circle, rgba(255, 107, 157, 0.07) 1.2px, transparent 1.2px);
        background-size: 28px 28px;
        z-index: 0;
        pointer-events: none;
    }

    .float-layer {
        position: absolute;
        inset: 0;
        z-index: 1;
        pointer-events: none;
    }

    .float-item {
        position: absolute;
        opacity: 0.3;
        animation-name: float-gentle;
        animation-iteration-count: infinite;
        animation-timing-function: ease-in-out;
    }

    @keyframes float-gentle {
        0%, 100% { transform: translateY(0) rotate(0deg); }
        50%      { transform: translateY(-18px) rotate(6deg); }
    }

    .hero-content {
        position: relative;
        z-index: 10;
        display: grid;
        place-items: center;
        gap: 1.5rem;
        width: 100%;
        max-width: 500px;
    }

    @media (min-width: 768px) {
        .hero { padding: 3rem 1.5rem 4rem; }
        .hero-content { max-width: 540px; gap: 1.75rem; }
    }

    @media (min-width: 1024px) {
        .hero { padding: 4rem 2rem 5rem; }
        .hero-content { max-width: 580px; }
    }

    .title-block {
        text-align: center;
        display: grid;
        gap: 0.75rem;
        width: 100%;
    }

    .eyebrow {
        margin: 0;
        font-size: 0.85rem;
        letter-spacing: 0.3em;
        text-transform: uppercase;
        color: #b0305a;
        font-weight: 600;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
        text-shadow: 0 1px 3px rgba(255, 255, 255, 0.8);
    }

    .eyebrow-star {
        color: #c2780a;
        font-size: 0.7rem;
    }

    .title {
        margin: 0;
        font-size: clamp(2.2rem, 6.5vw, 3.8rem);
        line-height: 1;
        font-weight: 700;
        color: #3a2222;
        text-transform: uppercase;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.15rem;
        text-shadow:
            0 2px 8px rgba(255, 255, 255, 0.75),
            0 1px 2px rgba(255, 255, 255, 0.9);
    }

    .title-amp {
        font-size: 0.5em;
        font-weight: 300;
        color: var(--color-primary);
        font-style: italic;
        margin: 0.2rem 0;
    }

    .title-accent {
        color: var(--color-primary-dark);
    }

    .meta-row {
        display: inline-flex;
        align-items: center;
        gap: 0.85rem;
        background: rgba(255, 255, 255, 0.7);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid rgba(255, 255, 255, 0.8);
        border-radius: 999px;
        padding: 0.55rem 1.2rem;
        margin: 0.4rem auto 0;
        box-shadow: 0 4px 20px rgba(255, 107, 157, 0.1);
        flex-wrap: wrap;
        justify-content: center;
    }

    .meta-item {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        color: var(--color-text);
        font-size: 1rem;
        font-weight: 500;
        letter-spacing: 0.04em;
    }

    .meta-icon {
        width: 16px;
        height: 16px;
        color: var(--color-primary);
    }

    .meta-divider {
        width: 4px;
        height: 4px;
        border-radius: 50%;
        background: var(--color-primary);
        opacity: 0.5;
    }

    .photo-wrapper {
        position: relative;
        display: grid;
        place-items: center;
        margin: 0.25rem 0;
    }

    .photo-frame {
        position: relative;
        width: 200px;
        height: 200px;
        border-radius: 50%;
        padding: 5px;
        background: linear-gradient(135deg, var(--color-primary), var(--color-accent));
        box-shadow:
            0 0 0 5px rgba(255, 255, 255, 0.5),
            0 10px 30px rgba(255, 107, 157, 0.3);
    }

    @media (min-width: 768px) {
        .photo-frame { width: 240px; height: 240px; }
    }

    @media (min-width: 1024px) {
        .photo-frame { width: 280px; height: 280px; }
    }

    .photo {
        width: 100%;
        height: 100%;
        object-fit: contain;
        border-radius: 50%;
        border: 3px solid white;
        display: block;
    }



    .actions {
        display: flex;
        gap: 0.75rem;
        justify-content: center;
        flex-wrap: wrap;
        margin-top: 0.25rem;
    }

    .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        padding: 0.85rem 1.5rem;
        border-radius: 1rem;
        font-weight: 800;
        font-size: 1rem;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        text-decoration: none;
        color: white;
        transition: transform 0.15s ease, background-color 0.2s ease;
        cursor: pointer;
        border: 0;
        border-bottom-width: 5px;
        border-bottom-style: solid;
    }

    @media (min-width: 768px) {
        .btn { font-size: 1.1rem; padding: 0.95rem 1.75rem; }
    }

    .btn:hover  { transform: translateY(-1px); }
    .btn:active {
        transform: translateY(4px);
        border-bottom-width: 0;
    }

    .btn-icon { width: 18px; height: 18px; }

    .btn-primary {
        background-color: #f472b6;
        border-bottom-color: #db2777;
    }
    .btn-primary:hover { background-color: #ec4899; }

    .btn-secondary {
        background-color: #38bdf8;
        border-bottom-color: #0284c7;
    }
    .btn-secondary:hover { background-color: #0ea5e9; }
</style>

<script>
    import AOS from 'aos';
    import 'aos/dist/aos.css';
    import confetti from 'canvas-confetti';

    AOS.init({ once: true });

    const colors = ['#ff6b9d', '#ffd166', '#4ecdc4', '#a78bfa', '#fb923c'];

    window.addEventListener('load', () => {
        setTimeout(() => {
            confetti({ particleCount: 80, spread: 70, origin: { y: 0.5 }, colors });
        }, 600);
    });

    let scrollCooldown = false;
    const burst = () => {
        if (scrollCooldown) return;
        scrollCooldown = true;
        confetti({ particleCount: 35, spread: 60, origin: { y: 0.8 }, colors });
        setTimeout(() => { scrollCooldown = false; }, 1200);
    };

    window.addEventListener('wheel', burst);

    let touchStartY = 0;
    window.addEventListener('touchstart', (e) => { touchStartY = e.touches[0].clientY; });
    window.addEventListener('touchmove', (e) => {
        if (e.touches[0].clientY - touchStartY < -20) burst();
    });
</script>
