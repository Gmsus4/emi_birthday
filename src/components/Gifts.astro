<section id="regalos" class="w-full py-16 px-4 bg-[linear-gradient(135deg,#e8d8b8_0%,#ecdfc4_50%,#f5ead4_100%)]">
  <div class="max-w-2xl mx-auto flex flex-col items-center text-center">
    <h2 class="font-script text-pooh-brown-dark text-[clamp(3rem,8vw,5rem)] m-0 leading-none">Regalos</h2>
    <img src="gifts.png" alt="" aria-hidden="true" class="w-80 md:w-96 my-6 opacity-90" />

    <p class="font-serif text-pooh-brown-dark max-w-lg m-0 leading-relaxed text-[clamp(1.4rem,2.4vw,1.5rem)] italic my-2 font-medium">
      {invitation.gifts.message}
    </p>
